<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: 'Helvetica Neue', Arial, sans-serif; background:#f0f4f8; margin:0; padding:0; }
    .wrapper { max-width:560px; margin:32px auto; background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.08); }
    .header { background:linear-gradient(135deg,#1a3a5c,#2a5298); padding:28px 32px; }
    .header h1 { color:#fff; font-size:20px; margin:0; }
    .header p { color:rgba(255,255,255,.8); font-size:13px; margin:4px 0 0; }
    .body { padding:28px 32px; }
    .label { font-size:12px; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:.05em; margin-bottom:2px; }
    .value { font-size:15px; color:#1e293b; margin-bottom:16px; }
    .divider { border:none; border-top:1px solid #e2e8f0; margin:20px 0; }
    .footer { background:#f8fafc; padding:16px 32px; font-size:12px; color:#94a3b8; text-align:center; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>🚗 出張報告のお知らせ</h1>
      <p>Kai Architect</p>
    </div>
    <div class="body">
      <p style="color:#475569; margin-top:0;">以下の出張報告が作成されました。</p>

      <div class="label">現場</div>
      <div class="value"><strong><%= @site.name %></strong><br>
        <span style="font-size:13px; color:#64748b;">📍 <%= @site.address %></span>
      </div>

      <div class="label">出張期間</div>
      <div class="value"><%= l @business_trip.started_at %> 〜 <%= l @business_trip.ended_at %></div>

      <div class="label">担当者</div>
      <div class="value"><%= @user.name %></div>

      <div class="label">出張先</div>
      <div class="value"><%= @business_trip.destination %></div>

      <div class="label">目的</div>
      <div class="value" style="white-space:pre-line;"><%= @business_trip.purpose %></div>

      <% if @business_trip.report.present? %>
        <div class="label">報告内容</div>
        <div class="value" style="white-space:pre-line;"><%= @business_trip.report %></div>
      <% end %>

      <% if @business_trip.expenses.present? %>
        <div class="label">経費</div>
        <div class="value"><%= number_with_delimiter(@business_trip.expenses.to_i) %>円</div>
      <% end %>
    </div>
    <div style="padding:0 32px 28px;">
      <a href="<%= site_business_trip_url(@site, @business_trip) %>"
         style="display:inline-block;background:linear-gradient(135deg,#1a3a5c,#2a5298);color:#fff;
                text-decoration:none;padding:10px 24px;border-radius:8px;font-size:14px;font-weight:600;">
        出張報告を確認する →
      </a>
    </div>
    <div class="footer">
      このメールは Kai Architect から自動送信されています
    </div>
  </div>
</body>
</html>
