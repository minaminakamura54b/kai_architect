<% content_for :title, "新規登録" %>
<div class="auth-page">
  <div class="auth-card card">
    <div class="auth-header">
      <div class="auth-logo">🏗</div>
      <h1>新規アカウント登録</h1>
      <p>Kai Architect にようこそ</p>
    </div>
    <div class="card-body">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :name, "氏名", class: "form-label fw-semibold" %>
          <%= f.text_field :name, autofocus: true,
                class: "form-control #{'is-invalid' if resource.errors[:name].any?}",
                placeholder: "山田 太郎" %>
          <div class="invalid-feedback"><%= resource.errors[:name].first %></div>
        </div>

        <div class="mb-3">
          <%= f.label :email, "メールアドレス", class: "form-label fw-semibold" %>
          <%= f.email_field :email, autocomplete: "email",
                class: "form-control #{'is-invalid' if resource.errors[:email].any?}" %>
          <div class="invalid-feedback"><%= resource.errors[:email].first %></div>
        </div>

        <div class="mb-3">
          <%= f.label :password, "パスワード", class: "form-label fw-semibold" %>
          <% if @minimum_password_length %>
            <small class="text-muted ms-1">（<%= @minimum_password_length %>文字以上）</small>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
                class: "form-control #{'is-invalid' if resource.errors[:password].any?}" %>
          <div class="invalid-feedback"><%= resource.errors[:password].first %></div>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, "パスワード（確認）", class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "form-control #{'is-invalid' if resource.errors[:password_confirmation].any?}" %>
          <div class="invalid-feedback"><%= resource.errors[:password_confirmation].first %></div>
        </div>

        <%= f.submit "登録する", class: "btn btn-primary w-100" %>
      <% end %>

      <hr class="my-3">
      <div class="text-center small text-muted">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
