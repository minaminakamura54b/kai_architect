<% content_for :title, "点検記録" %>

<div class="page-header">
  <h1 class="page-title">点検記録</h1>
  <%= link_to "＋ 点検を記録", new_inspection_path, class: "btn btn-accent" %>
</div>

<% if @inspections.any? %>
  <div class="table-card">
    <table class="table">
      <thead>
        <tr>
          <th>点検日時</th>
          <th>現場</th>
          <th>担当者</th>
          <th>結果概要</th>
          <th>ステータス</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @inspections.each do |inspection| %>
          <tr>
            <td class="text-nowrap fw-semibold"><%= l inspection.inspected_at, format: :short %></td>
            <td><%= link_to inspection.site.name, inspection.site, class: "text-primary-custom fw-semibold" %></td>
            <td><%= inspection.user.name %></td>
            <td><%= truncate(inspection.result, length: 40) %></td>
            <td>
              <span class="badge badge-<%= inspection.status %>">
                <%= I18n.t("enums.inspection.status.#{inspection.status}", default: inspection.status) %>
              </span>
            </td>
            <td class="text-end">
              <%= link_to "詳細", site_inspection_path(inspection.site, inspection), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <p>点検記録がありません</p>
      <%= link_to "最初の点検を記録する", new_inspection_path, class: "btn btn-accent" %>
    </div>
  </div>
<% end %>
