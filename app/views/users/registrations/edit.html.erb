<% content_for :title, "アカウント設定" %>
<div class="row justify-content-center mt-4">
  <div class="col-md-6">
    <h1 class="h4 mb-4">アカウント設定</h1>
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= render "users/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :name, "氏名", class: "form-label fw-semibold" %>
            <%= f.text_field :name, autofocus: true, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :email, "メールアドレス", class: "form-label fw-semibold" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
          </div>

          <hr class="my-3">
          <p class="text-muted small">パスワードを変更する場合のみ入力してください</p>

          <div class="mb-3">
            <%= f.label :password, "新しいパスワード", class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
            <% if @minimum_password_length %>
              <div class="form-text"><%= @minimum_password_length %>文字以上</div>
            <% end %>
          </div>

          <div class="mb-3">
            <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label fw-semibold" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>

          <div class="mb-4">
            <%= f.label :current_password, "現在のパスワード", class: "form-label fw-semibold" %>
            <div class="form-text mb-1">変更を保存するには現在のパスワードが必要です</div>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
          </div>

          <%= f.submit "更新する", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>

    <div class="mt-4 text-end">
      <%= button_to "アカウントを削除する", registration_path(resource_name),
            method: :delete,
            data: { confirm: "本当に削除しますか？この操作は取り消せません。" },
            class: "btn btn-sm btn-outline-danger" %>
    </div>
  </div>
</div>
